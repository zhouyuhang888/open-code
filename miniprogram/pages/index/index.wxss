.page {
  padding-bottom: 20rpx;
}

.header {
  padding: 20rpx var(--spacing-base);
  background: var(--color-bg);
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 44rpx;
  padding: 16rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-text {
  color: var(--color-text-light);
  font-size: var(--font-size-base);
}

.banner {
  width: 100%;
  height: 340rpx;
  padding: 0 var(--spacing-base);
}

.banner-img {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-base);
}

.category-nav {
  display: flex;
  justify-content: space-around;
  padding: var(--spacing-base);
  background: #fff;
  margin: var(--spacing-base);
  border-radius: var(--radius-base);
  flex-wrap: wrap;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
  margin-bottom: var(--spacing-sm);
  padding: var(--spacing-xs) 0;
}

.nav-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.nav-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.section {
  padding: 0 var(--spacing-base);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-base) 0;
}

.section-title {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: var(--color-text);
}

.section-more {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-base);
}

.goods-item {
  background: #fff;
  border-radius: var(--radius-base);
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.goods-img {
  width: 100%;
  height: 340rpx;
}

.goods-info {
  padding: var(--spacing-sm) var(--spacing-base);
}

.goods-name {
  font-size: var(--font-size-base);
  line-height: 1.4;
  margin-bottom: var(--spacing-xs);
  height: 80rpx;
}

.goods-tags {
  display: flex;
  gap: 8rpx;
  margin-bottom: var(--spacing-xs);
}

.tag {
  font-size: 20rpx;
  color: var(--color-primary);
  background: rgba(91,140,42,0.1);
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-sales {
  font-size: 22rpx;
  color: var(--color-text-light);
}
