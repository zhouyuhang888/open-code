<view class="page">
  <view class="user-header" bindtap="doLogin">
    <image class="avatar" src="{{userInfo.avatarUrl || 'https://via.placeholder.com/120'}}" mode="aspectFill" />
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || '点击登录'}}</text>
      <text class="welcome">{{userInfo.nickName ? '欢迎回来' : '登录享受更多服务'}}</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <view class="order-stats card">
    <view class="stat-item" bindtap="goOrderList" data-status="all">
      <text class="stat-num">{{orderCounts.all || 0}}</text>
      <text class="stat-label">全部订单</text>
    </view>
    <view class="stat-item" bindtap="goOrderList" data-status="pending_payment">
      <text class="stat-num">{{orderCounts.pending_payment || 0}}</text>
      <text class="stat-label">待付款</text>
    </view>
    <view class="stat-item" bindtap="goOrderList" data-status="pending_ship">
      <text class="stat-num">{{orderCounts.pending_ship || 0}}</text>
      <text class="stat-label">待发货</text>
    </view>
    <view class="stat-item" bindtap="goOrderList" data-status="shipped">
      <text class="stat-num">{{orderCounts.shipped || 0}}</text>
      <text class="stat-label">待收货</text>
    </view>
    <view class="stat-item" bindtap="goOrderList" data-status="completed">
      <text class="stat-num">{{orderCounts.completed || 0}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <view class="menu-list card">
    <view class="menu-item" bindtap="goAddress">
      <text class="menu-icon">📍</text>
      <text class="menu-label">收货地址</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMerchant">
      <text class="menu-icon">🏪</text>
      <text class="menu-label">商家入驻</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="contactService">
      <text class="menu-icon">💬</text>
      <text class="menu-label">联系客服</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
