<view class="page">
  <view class="form">
    <view class="form-item">
      <text class="label">收货人</text>
      <input class="input" placeholder="请输入收货人姓名" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
    </view>
    <view class="form-item">
      <text class="label">所在地区</text>
      <picker mode="region" value="{{region}}" bindchange="onRegionChange">
        <text class="input {{region.length === 0 ? 'placeholder' : ''}}">{{region.length > 0 ? region.join(' ') : '请选择省/市/区'}}</text>
      </picker>
    </view>
    <view class="form-item">
      <text class="label">详细地址</text>
      <input class="input" placeholder="街道、门牌号等" value="{{form.detail}}" bindinput="onInput" data-field="detail" />
    </view>
    <view class="form-item switch-item">
      <text class="label">设为默认地址</text>
      <switch checked="{{form.isDefault}}" color="#5B8C2A" bindchange="onDefaultChange" />
    </view>
  </view>

  <view class="btn-wrap">
    <button class="btn-primary" bindtap="saveAddress">保存</button>
    <button class="btn-secondary" wx:if="{{isEdit}}" bindtap="deleteAddress">删除地址</button>
  </view>
</view>
