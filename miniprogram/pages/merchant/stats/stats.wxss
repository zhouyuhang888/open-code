.page {
  padding: var(--spacing-base);
  padding-bottom: 120rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-base);
  margin-bottom: var(--spacing-lg);
}

.stat-card {
  background: #fff;
  border-radius: var(--radius-base);
  padding: var(--spacing-lg);
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text);
  display: block;
}

.stat-label {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  margin-top: var(--spacing-xs);
  display: block;
}

.section {
  background: #fff;
  border-radius: var(--radius-base);
  padding: var(--spacing-base);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  display: block;
  margin-bottom: var(--spacing-base);
}

.order-item {
  display: flex;
  justify-content: space-between;
  padding: var(--spacing-sm) 0;
  border-bottom: 2rpx solid var(--color-border);
  font-size: var(--font-size-sm);
}

.order-item:last-child { border-bottom: none; }

.order-no {
  flex: 1;
  color: var(--color-text-light);
}

.order-amount {
  color: var(--color-danger);
  font-weight: 600;
  width: 120rpx;
  text-align: right;
}

.order-status { width: 100rpx; text-align: right; }
.order-status.pending_ship { color: var(--color-warning); }
.order-status.shipped { color: var(--color-primary); }
.order-status.completed { color: var(--color-text-light); }

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  padding: 12rpx 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 2rpx solid var(--color-border);
  z-index: 50;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 20rpx;
  color: var(--color-text-light);
}

.nav-item.active { color: var(--color-primary); }
.nav-item text:first-child { font-size: 40rpx; }
