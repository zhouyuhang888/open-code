<view class="page">
  <view class="tabs">
    <view class="tab {{activeTab === 'on' ? 'active' : ''}}" bindtap="switchTab" data-tab="on">已上架</view>
    <view class="tab {{activeTab === 'off' ? 'active' : ''}}" bindtap="switchTab" data-tab="off">已下架</view>
  </view>

  <empty-state wx:if="{{goodsList.length === 0}}" icon="📦" title="暂无商品" desc="点击下方按钮添加商品" btnText="添加商品" bindtap="addGoods" />

  <view class="goods-list" wx:else>
    <view class="goods-item" wx:for="{{goodsList}}" wx:key="*this">
      <image class="goods-img" src="{{item.images && item.images[0] || 'https://via.placeholder.com/160'}}" mode="aspectFill" />
      <view class="goods-info">
        <text class="goods-name ellipsis">{{item.name}}</text>
        <text class="goods-price">¥{{item.price}} <text class="goods-stock">库存: {{item.stock || 0}}</text></text>
        <text class="goods-sales">已售 {{item.sales || 0}}</text>
      </view>
      <view class="goods-actions">
        <button class="action-btn" bindtap="editGoods" data-id="{{item._id}}">编辑</button>
        <button class="action-btn {{item.status === 'on' ? 'danger' : 'primary'}}" bindtap="toggleStatus" data-id="{{item._id}}" data-status="{{item.status}}">{{item.status === 'on' ? '下架' : '上架'}}</button>
      </view>
    </view>
  </view>

  <view class="add-btn-wrap">
    <button class="btn-primary" bindtap="addGoods">+ 添加商品</button>
  </view>

  <view class="bottom-nav">
    <view class="nav-item active" bindtap="goGoodsList"><text>📦</text><text>商品</text></view>
    <view class="nav-item" bindtap="goOrders"><text>📋</text><text>订单</text></view>
    <view class="nav-item" bindtap="goStats"><text>📊</text><text>统计</text></view>
  </view>
</view>
