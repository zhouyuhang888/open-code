.page {
  padding-bottom: 120rpx;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--color-border);
}

.tab {
  flex: 1;
  text-align: center;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  position: relative;
}

.tab.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

.goods-list {
  padding: var(--spacing-base);
}

.goods-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-base);
  padding: var(--spacing-base);
  margin-bottom: var(--spacing-base);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.goods-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  margin-right: var(--spacing-base);
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  min-width: 0;
}

.goods-name {
  font-size: var(--font-size-base);
  margin-bottom: var(--spacing-xs);
}

.goods-price {
  font-size: var(--font-size-lg);
  color: var(--color-danger);
  font-weight: 600;
  display: block;
}

.goods-stock {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  font-weight: 400;
}

.goods-sales {
  font-size: 22rpx;
  color: var(--color-text-light);
  display: block;
  margin-top: 4rpx;
}

.goods-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
  margin-left: var(--spacing-sm);
}

.action-btn {
  padding: 4rpx 20rpx !important;
  height: 52rpx !important;
  line-height: 52rpx !important;
  font-size: 22rpx !important;
  border-radius: 26rpx !important;
  margin: 0 !important;
  background: var(--color-primary) !important;
  color: #fff !important;
}

.action-btn.danger {
  background: var(--color-danger) !important;
}

.action-btn::after { border: none !important; }

.add-btn-wrap {
  padding: var(--spacing-base);
}

.add-btn-wrap .btn-primary { width: 100%; }

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  padding: 12rpx 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 2rpx solid var(--color-border);
  z-index: 50;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 20rpx;
  color: var(--color-text-light);
}

.nav-item.active {
  color: var(--color-primary);
}

.nav-item text:first-child {
  font-size: 40rpx;
}
