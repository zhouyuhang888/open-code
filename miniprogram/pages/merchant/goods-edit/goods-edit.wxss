.page {
  padding: var(--spacing-base);
}

.form {
  background: #fff;
  border-radius: var(--radius-base);
  padding: var(--spacing-base);
}

.form-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-base) 0;
  border-bottom: 2rpx solid var(--color-border);
  flex-wrap: wrap;
}

.form-item:last-child { border-bottom: none; }

.label {
  font-size: var(--font-size-base);
  color: var(--color-text);
  width: 160rpx;
  flex-shrink: 0;
}

.input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--color-text);
  text-align: right;
}

.input.placeholder {
  color: var(--color-text-light);
}

.upload-item {
  flex-direction: column;
  align-items: flex-start;
}

.upload-area {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-sm);
  width: 100%;
}

.uploaded-img {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.uploaded-img image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-sm);
}

.remove-img {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  text-align: center;
  line-height: 36rpx;
  border-radius: 50%;
  font-size: 24rpx;
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: var(--color-text-light);
}

.btn-wrap {
  margin-top: var(--spacing-xl);
}

.btn-wrap .btn-primary { width: 100%; }
