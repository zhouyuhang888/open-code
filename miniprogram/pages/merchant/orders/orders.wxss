.page {
  padding-bottom: 120rpx;
}

.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab {
  flex: 1;
  text-align: center;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  position: relative;
}

.tab.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

.order-list { padding: var(--spacing-base); }

.order-card {
  background: #fff;
  border-radius: var(--radius-base);
  margin-bottom: var(--spacing-base);
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-base);
  border-bottom: 2rpx solid var(--color-border);
  font-size: 22rpx;
  color: var(--color-text-light);
}

.order-status.pending_ship { color: var(--color-warning); }
.order-status.shipped { color: var(--color-primary); }
.order-status.completed { color: var(--color-text-light); }

.order-goods {
  display: flex;
  padding: var(--spacing-sm) var(--spacing-base);
  border-bottom: 2rpx solid var(--color-border);
}

.goods-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  font-size: var(--font-size-sm);
}

.goods-name { font-size: var(--font-size-base); }

.order-address {
  padding: var(--spacing-sm) var(--spacing-base);
  font-size: 22rpx;
  color: var(--color-text-light);
  border-bottom: 2rpx solid var(--color-border);
}

.order-address text { display: block; }

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-base);
  font-size: var(--font-size-sm);
}

.actions { display: flex; gap: var(--spacing-sm); }

.action-btn {
  padding: 8rpx 28rpx !important;
  height: 56rpx !important;
  line-height: 56rpx !important;
  font-size: 24rpx !important;
  border-radius: 28rpx !important;
  margin: 0 !important;
}

.action-btn.primary { background: var(--color-primary) !important; color: #fff !important; }
.action-btn::after { border: none !important; }

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  padding: 12rpx 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 2rpx solid var(--color-border);
  z-index: 50;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 20rpx;
  color: var(--color-text-light);
}

.nav-item.active { color: var(--color-primary); }
.nav-item text:first-child { font-size: 40rpx; }
