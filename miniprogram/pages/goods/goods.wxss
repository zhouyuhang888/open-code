.page {
  padding-bottom: 120rpx;
}

.goods-swiper {
  width: 100%;
  height: 750rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

.goods-info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.goods-name {
  font-size: var(--font-size-xl);
  font-weight: 600;
  line-height: 1.4;
}

.goods-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.goods-meta {
  display: flex;
  gap: var(--spacing-base);
  font-size: 24rpx;
  color: var(--color-text-light);
}

.meta-item {
  position: relative;
  padding-right: var(--spacing-base);
}

.meta-item + .meta-item::before {
  content: '|';
  position: absolute;
  left: -16rpx;
  color: var(--color-border);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  display: block;
  margin-bottom: var(--spacing-sm);
}

.farmer-content {
  display: flex;
  align-items: center;
  gap: var(--spacing-base);
}

.farmer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.farmer-detail {
  flex: 1;
}

.farmer-name {
  font-size: var(--font-size-base);
  font-weight: 500;
}

.farmer-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.detail-section {
  line-height: 1.6;
}

/* 规格面板 */
.spec-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
}

.panel-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: var(--spacing-lg);
  max-height: 70vh;
}

.panel-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-base);
  margin-top: -80rpx;
}

.panel-stock {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
  margin-top: var(--spacing-xs);
}

.spec-scroll {
  max-height: 50vh;
  margin-top: var(--spacing-base);
}

.spec-group {
  margin-bottom: var(--spacing-base);
}

.spec-label {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-sm);
  display: block;
}

.spec-options {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.spec-option {
  padding: 12rpx 24rpx;
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  color: var(--color-text);
}

.spec-option.active {
  border-color: var(--color-primary);
  background: rgba(91,140,42,0.08);
  color: var(--color-primary);
}

.quantity-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-base);
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 0;
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border: 2rpx solid var(--color-border);
  font-size: var(--font-size-lg);
}

.qty-num {
  width: 80rpx;
  text-align: center;
  font-size: var(--font-size-lg);
  border-top: 2rpx solid var(--color-border);
  border-bottom: 2rpx solid var(--color-border);
  height: 60rpx;
  line-height: 60rpx;
}

.confirm-btn {
  width: 100%;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 12rpx 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 2rpx solid var(--color-border);
  z-index: 50;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 90rpx;
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.bar-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.btn-cart {
  flex: 1;
  margin: 0 var(--spacing-xs);
  height: 76rpx;
  line-height: 76rpx;
  background: var(--color-primary-light) !important;
  color: #fff !important;
  border-radius: 38rpx !important;
  font-size: var(--font-size-base) !important;
}

.btn-cart::after {
  border: none !important;
}

.btn-buy {
  flex: 1;
  margin: 0 var(--spacing-xs);
  height: 76rpx;
  line-height: 76rpx;
  background: var(--color-secondary) !important;
  color: #fff !important;
  border-radius: 38rpx !important;
  font-size: var(--font-size-base) !important;
}

.btn-buy::after {
  border: none !important;
}
