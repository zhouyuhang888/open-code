<view class="page">
  <view class="tabs">
    <view class="tab {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab {{activeTab === 'pending_payment' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending_payment">待付款</view>
    <view class="tab {{activeTab === 'pending_ship' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending_ship">待发货</view>
    <view class="tab {{activeTab === 'shipped' ? 'active' : ''}}" bindtap="switchTab" data-tab="shipped">待收货</view>
    <view class="tab {{activeTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">已完成</view>
  </view>

  <empty-state wx:if="{{orderList.length === 0}}" icon="📋" title="暂无订单" desc="快去选购有机好物吧" btnText="去首页" bindtap="goHome" />

  <view class="order-list" wx:else>
    <view class="order-card" wx:for="{{orderList}}" wx:key="*this" bindtap="goDetail" data-id="{{item._id}}">
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo || item._id}}</text>
        <text class="order-status {{item.status}}">{{statusMap[item.status]}}</text>
      </view>
      <view class="order-goods" wx:for="{{item.items}}" wx:for-item="gi" wx:key="goodsId">
        <image class="goods-img" src="{{gi.image || 'https://via.placeholder.com/120'}}" mode="aspectFill" />
        <view class="goods-info">
          <text class="goods-name ellipsis">{{gi.name}}</text>
          <text class="goods-spec">{{gi.spec}}</text>
          <text class="goods-price">¥{{gi.price}} × {{gi.quantity}}</text>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-total">共 {{item.totalCount || (item.items ? item.items.length : 0)}} 件 合计：<text class="total-price">¥{{item.totalAmount}}</text></text>
        <view class="order-actions" wx:if="{{item.status === 'pending_payment'}}">
          <button class="action-btn cancel" bindtap="cancelOrder" data-id="{{item._id}}">取消订单</button>
          <button class="action-btn primary" bindtap="payOrder" data-id="{{item._id}}">去支付</button>
        </view>
        <view class="order-actions" wx:if="{{item.status === 'shipped'}}">
          <button class="action-btn primary" bindtap="confirmReceive" data-id="{{item._id}}">确认收货</button>
        </view>
      </view>
    </view>
  </view>

  <load-more loading="{{loading}}" hasMore="{{hasMore}}" />
</view>
