.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 44rpx;
  padding: 16rpx 28rpx;
  margin: 20rpx var(--spacing-base);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-text {
  color: var(--color-text-light);
  font-size: var(--font-size-base);
}

.content {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.left-menu {
  width: 180rpx;
  background: #f5f5f0;
  height: 100%;
}

.menu-item {
  padding: 28rpx 20rpx;
  text-align: center;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  border-left: 4rpx solid transparent;
}

.menu-item.active {
  background: var(--color-bg);
  color: var(--color-primary);
  border-left-color: var(--color-primary);
  font-weight: 600;
}

.right-content {
  flex: 1;
  padding: var(--spacing-base);
  height: 100%;
}

.cate-banner {
  width: 100%;
  height: 200rpx;
  border-radius: var(--radius-base);
  margin-bottom: var(--spacing-base);
}

.sub-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--spacing-base);
}

.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-base);
}

.goods-item {
  background: #fff;
  border-radius: var(--radius-base);
  padding: var(--spacing-sm);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.goods-img {
  width: 100%;
  height: 240rpx;
  border-radius: var(--radius-sm);
}

.goods-name {
  font-size: var(--font-size-sm);
  margin: var(--spacing-xs) 0;
  height: 60rpx;
}
