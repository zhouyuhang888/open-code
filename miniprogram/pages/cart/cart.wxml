<view class="page">
  <empty-state wx:if="{{cartList.length === 0}}" icon="🛒" title="购物车空空如也" desc="去逛逛，发现有机好物吧" btnText="去逛逛" bindtap="goHome" />

  <view class="cart-list" wx:else>
    <view class="cart-item" wx:for="{{cartList}}" wx:key="*this">
      <view class="checkbox {{item.checked ? 'checked' : ''}}" bindtap="toggleCheck" data-id="{{item._id}}">
        <text wx:if="{{item.checked}}">✓</text>
      </view>
      <image class="item-img" src="{{item.goodsInfo && item.goodsInfo.images ? item.goodsInfo.images[0] : item.image || 'https://via.placeholder.com/160'}}" mode="aspectFill" />
      <view class="item-info">
        <text class="item-name ellipsis-2">{{item.goodsInfo ? item.goodsInfo.name : item.name}}</text>
        <text class="item-spec">{{item.spec || '默认'}}</text>
        <view class="item-bottom">
          <price-display price="{{item.goodsInfo ? item.goodsInfo.price : item.price}}" />
          <view class="quantity-control">
            <text class="qty-btn" bindtap="decreaseQty" data-id="{{item._id}}">−</text>
            <text class="qty-num">{{item.quantity}}</text>
            <text class="qty-btn" bindtap="increaseQty" data-id="{{item._id}}">+</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-bar" wx:if="{{cartList.length > 0}}">
    <view class="checkbox-all {{allChecked ? 'checked' : ''}}" bindtap="toggleAll">
      <text wx:if="{{allChecked}}">✓</text>
      <text class="all-label">全选</text>
    </view>
    <view class="total-section">
      <text class="total-text">合计：</text>
      <price-display price="{{totalAmount}}" />
    </view>
    <button class="btn-primary checkout-btn" disabled="{{!hasChecked}}" bindtap="checkout">结算({{checkedCount}})</button>
  </view>
</view>
