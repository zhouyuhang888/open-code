.page {
  padding: var(--spacing-base);
}

.search-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-base);
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 44rpx;
  padding: 12rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.s-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: var(--font-size-base);
  height: 48rpx;
}

.clear-btn {
  font-size: 28rpx;
  color: var(--color-text-light);
  padding: 0 8rpx;
}

.cancel-btn {
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  margin-left: var(--spacing-base);
  flex-shrink: 0;
}

.history-section {
  margin-top: var(--spacing-base);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-base);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
}

.clear-history {
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.history-tag {
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: var(--radius-base);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.results {
  margin-top: var(--spacing-base);
}

.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-base);
}

.goods-item {
  background: #fff;
  border-radius: var(--radius-base);
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.goods-img {
  width: 100%;
  height: 300rpx;
}

.goods-info {
  padding: var(--spacing-sm) var(--spacing-base);
}

.goods-name {
  font-size: var(--font-size-sm);
  line-height: 1.4;
  margin-bottom: var(--spacing-xs);
  height: 60rpx;
}
