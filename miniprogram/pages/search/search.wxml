<view class="page">
  <view class="search-header">
    <view class="search-input-wrap">
      <text class="s-icon">🔍</text>
      <input class="search-input" placeholder="搜索有机土特产..." value="{{keyword}}" bindinput="onInput" focus="{{true}}" bindconfirm="doSearch" />
      <text class="clear-btn" wx:if="{{keyword}}" bindtap="clearSearch">✕</text>
    </view>
    <text class="cancel-btn" bindtap="goBack">取消</text>
  </view>

  <view class="history-section" wx:if="{{searchHistory.length > 0 && results.length === 0}}">
    <view class="section-header">
      <text class="section-title">搜索历史</text>
      <text class="clear-history" bindtap="clearHistory">清空</text>
    </view>
    <view class="history-tags">
      <text class="history-tag" wx:for="{{searchHistory}}" wx:key="*this" bindtap="searchByKeyword" data-keyword="{{item}}">{{item}}</text>
    </view>
  </view>

  <view class="results" wx:if="{{results.length > 0}}">
    <view class="goods-grid">
      <view class="goods-item" wx:for="{{results}}" wx:key="*this" data-id="{{item._id}}" bindtap="goGoodsDetail">
        <image class="goods-img" src="{{item.images && item.images[0]}}" mode="aspectFill" />
        <view class="goods-info">
          <text class="goods-name ellipsis-2">{{item.name}}</text>
          <price-display price="{{item.price}}" />
        </view>
      </view>
    </view>
    <load-more loading="{{loading}}" hasMore="{{hasMore}}" />
  </view>

  <empty-state wx:if="{{searched && results.length === 0}}" icon="🔍" title="未找到相关商品" desc="换个关键词试试" />
</view>
